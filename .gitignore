# Ignore MacOs specific files
.DS_Store
# Ignore Python bytecode files
*.pyc
.pytest_cache
__pycache__/
# Ignore Python egg files and directories
*.egg-info/
*.egg
# Ignore build artifacts
build/
dist/
# Ignore environment settings
.env
# Ignore idea stuff
.idea/
# Ignore virtual environment
venv/
.venv/
# Ignore the deployment's real user list (the package ships users.example.yaml)
/users.yaml
# Ignore runtime artifacts (logs, pidfile)
/var/
# Ignore coverage reports
.coverage

# Xcode
DerivedData/
*.xcuserstate
xcuserdata/
*.xcworkspace/xcuserdata/